# Local Postgres connection for the price worker
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=Supabase123!
DB_NAME=postgres

# How often to sync prices (seconds). Default: 120 (2 minutes)
# Keep >= 120 to stay well under GeckoTerminal free tier (30 req/min)
SYNC_INTERVAL_SECONDS=120

# Max pairs per multi-pool batch call (GeckoTerminal max: 30)
BATCH_SIZE=30

# Networks to sync (comma-separated)
NETWORKS=bsc,base,solana
