# Server
PORT=8080
ENVIRONMENT=development

# Database - Supabase PostgreSQL
DB_HOST=your-project-ref.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-supabase-password
DB_NAME=postgres
DB_SSL_MODE=require
DB_MAX_CONNS=25

# Redis - Upstash
REDIS_URL=your-upstash-redis.upstash.io
REDIS_PASSWORD=your-upstash-password

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this

# Settlement Contracts (already set, can override)
SETTLEMENT_CONTRACT_BSC=0x4896ebe3EE1436a58c690A8021301A6bFD6BD4E7
SETTLEMENT_CONTRACT_BASE=0x723da0ef5eea8370015465e9Cf2513D7e48e1b61

# RPC URLs (get from Alchemy/Infura)
INFURA_URL=https://bsc.nodereal.io/
ALCHEMY_URL=https://base-mainnet.g.alchemy.com/v2/your-key